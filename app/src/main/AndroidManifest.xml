<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Bondwidth is offline by design and must never access the network.
      These lines force-remove network permissions even if a merged
      library manifest tries to add them. The CI build fails if the
      final APK declares either permission.
    -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:node="remove" />

    <!-- Read-only access to contacts, used to import people and to power
         the all-in-one Contacts browser. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Write contacts (all-in-one Contacts manager: edit / create /
         delete entries in the system Contacts provider). Requested at
         runtime the first time the user edits or creates a contact. -->
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!-- Read-only access to the call log, used to detect recent calls. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Place phone calls from the in-app dialer (all-in-one). Runtime. -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- Read phone state and SIM info, used to: route outgoing calls
         through the right SIM, surface call state to the in-call UI,
         and qualify as a default-dialer app. Runtime. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <!-- Default-dialer privileged permissions. Auto-granted when
         Bondwidth holds ROLE_DIALER; declared so the compile-time
         checks for the InCallService and call-answering flows can
         compile against them. -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- Required for hosting the InCallService while a call is active. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Post reminder notifications (runtime permission on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Android 11+ requires explicit <queries> for PackageManager.getPackageInfo
      and Intent resolution against other apps. We only check for WhatsApp and
      Signal, and we only ever launch tel: / sms: / https://wa.me / signal.me
      schemes — no broad QUERY_ALL_PACKAGES.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="sms" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="wa.me" />
        </intent>
        <package android:name="com.whatsapp" />
        <package android:name="org.thoughtcrime.securesms" />
    </queries>

    <application
        android:name=".FriendsApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.Friends">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Friends">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.UpcomingWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/upcoming_widget_info" />
        </receiver>

        <receiver
            android:name=".notification.MarkAsWishedReceiver"
            android:exported="false" />
    </application>
</manifest>
